library ieee;
use ieee.std_logic_1164.all;

entity ALU_tbv2 is
end ALU_tbv2;

architecture behavioral of ALU_tb is

	component LSR4
		port(
			X , Y : in  std_logic_vector(3 downto 0);
			R : out std_logic_vector(3 downto 0)
		);
	end component;
	
	signal X_TB, Y_TB, R_TB : std_logic_vector(3 downto 0);
	
begin
	
	UUT: LSR4 port map (
		X => X_TB,
		Y => Y_TB,
		R => R_TB
	);

process begin

	X_TB <= "0110";
	Y_TB <= "1100";
	wait for 10ns;
	
end behavioral;