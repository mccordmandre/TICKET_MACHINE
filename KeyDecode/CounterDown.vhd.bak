library ieee;

use ieee.std_logic_1164.all;

entity CounterDown is
 port(

   --Input Port
     
	  Clk: in std_logic;
	  PL, CE: in std_logic;
    
	 --Output Port
     
	  Q: out std_logic_vector(3 downto 0));

	  
  end CounterDown;
  
  architecture structural of CounterDown is
component adder is
 port(
   
	--Input Port
     A, B: in std_logic_vector(3 downto 0);
	  Ci: in std_logic;
    
	 --Output Port
     S: out std_logic_vector(3 downto 0);
	  Co: out std_logic);

end component;

component MUX1bit is
port(
   
	--Input port
	
	  A, B : in std_logic;
     S : in std_logic;
	  
	--Output port
	
     Y : out std_logic);
	  
end component;


 

signal carry : std_logic_vector(3 downto 1);

begin

U1 :  port map ( A => A(0), B => B(0), Ci => Ci, S => S(0), Co => carry(1));
U2 :  port map ( A => A(1), B => B(1), Ci => carry(1), S => S(1), Co => carry(2));
U3 :  port map ( A => A(2), B => B(2), Ci => carry(2), S => S(2), Co => carry(3));
U4 :  port map ( A => A(3), B => B(3), Ci => carry(3), S => S(3), Co => Co);

end structural;
