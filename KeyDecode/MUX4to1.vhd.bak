library ieee;
use ieee.std_logic_1164.all;


entity MUX4to1 is
  port(
    
	--Input port
	 
	 A, B, C, D, S0, S1 : in std_logic;  
   
	 
	 --Output port
	 
        Y : out std_logic);
		  
end MUX4to1;


architecture structural of MUX4to1 is
component MUX is
  port(
   
	--Input port
	
	 A : in std_logic_vector(3 downto 0);
	 B : in std_logic_vector(3 downto 0);
    S : in std_logic;
	 
	 --Output port
	 
    R : out std_logic_vector(3 downto 0));	

 end MUX;
  

signal fio0 : std_logic;
signal fio1 : std_logic;

begin

U1 : MUX port map(A => A, B => B, R => fio0);

U2 : MUX port map(A => A, B => B, R => fio1);

U3 : MUX port map(A => fio0, B => fio1, S => S, R => R);

end structural;
