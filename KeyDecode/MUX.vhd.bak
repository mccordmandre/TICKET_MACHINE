library ieee;
use ieee.std_logic_1164.all;



entity MUX is
 port(
   A : in std_logic_vector(3 downto 0);
	B : in std_logic_vector(3 downto 0);
   S : in std_logic;
   R : out std_logic_vector(3 downto 0));	

 end MUX;
  
architecture structural of MUX is
begin


 R <= (not S and A) or (S and B);
 
 end structural;
  